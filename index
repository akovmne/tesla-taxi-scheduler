<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Tesla Taxi Scheduler</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">
  <h1>🚖 Tesla Taxi Charging Schedule</h1>

  <div class="card">
    <h2>Add Entry</h2>

    <input id="driver" placeholder="Driver name">
    <input id="date" type="date">

    <input id="shift" placeholder="Shift (e.g. 08:00 - 16:00)">
    <input id="chargeStart" placeholder="Charging start (e.g. 22:00)">
    <input id="chargeEnd" placeholder="Charging end (e.g. 02:00)">

    <button onclick="addRow()">Add to Table</button>
  </div>

  <div class="card">
    <h2>📅 Daily Charging Table</h2>

    <table>
      <thead>
        <tr>
          <th>Driver</th>
          <th>Date</th>
          <th>Shift</th>
          <th>Charging Start</th>
          <th>Charging End</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>

</div>

<script src="app.js"></script>
</body>
</html>
